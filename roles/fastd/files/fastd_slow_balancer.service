[Unit]
Description=fastd_slow_balancer
Wants=vxlan0.service

[Service]
Type=simple
ExecStart=/usr/bin/fastd-slow-balancer -c /etc/fastd_slow_balancer.json
Restart=always
RestartSec=5s

[Install]
WantedBy=multi-user.target
